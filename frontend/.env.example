# ============================================
# PivotPoint — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ---- REQUIRED: Supabase Connection ----

# Your Supabase project URL.
# Found at: Supabase Dashboard → Settings → API → Project URL
# Example: https://abcdefghijklmnopqrst.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon / publishable key (NOT the service_role key).
# Found at: Supabase Dashboard → Settings → API → anon public / publishable key
# Format: starts with "sb_publishable_" (modern) or "eyJ..." (legacy JWT)
# IMPORTANT: This is safe to expose to the client. Do NOT use the service_role key.
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# ---- OPTIONAL: API Integration Tests ----

# These are only needed if you run API integration tests:
#   npx vitest run tests/api.test.js
# Create a test user in your Supabase project first, then fill in below.
VITE_TEST_USER_EMAIL=your-test-user@example.com
VITE_TEST_USER_PASSWORD=your-password
