      "containerId": "Auth",
      "method": "POST",
      "sortNum": 10,
      "url": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
      "headers": [
        { "name": "apikey", "value": "{{supabaseAnonKey}}" },
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\"\n}"
      },
      "preScript": "",
      "testScript": "const json = JSON.parse(req.body);\r\nconst res = JSON.parse(res.text);\r\nif (res.access_token) {\r\n  thunder.setEnvVar('accessToken', res.access_token);\r\n  thunder.setEnvVar('userId', res.user.id);\r\n  thunder.setEnvVar('userEmail', res.user.email);\r\n}"
    },
